<%- include("partials/header", { title: "本人確認" }) %>

<%
const currentYear = new Date().getFullYear();
%>

<div class="clinic-page">
  <div class="clinic-card login-card">

    <h1>本人確認</h1>

    <p class="clinic-lead">
      患者番号と生年月日を入力してください。
    </p>

    <% if (typeof error !== "undefined" && error) { %>
      <div class="clinic-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/mypage" class="clinic-form">

      <label>
        <span>患者番号</span>
        <input
          type="text"
          name="patientNumber"
          inputmode="numeric"
          maxlength="5"
          autocomplete="off"
          placeholder="例：10001"
          required
        >
      </label>

      <label>
        <span>生年月日</span>

        <div class="birth-select">
          <select name="birthYear" required>
            <% for (let y = currentYear; y >= 1900; y--) { %>
              <option value="<%= y %>"><%= y %>年</option>
            <% } %>
          </select>

          <select name="birthMonth" required>
            <% for (let m = 1; m <= 12; m++) { %>
              <option value="<%= m %>"><%= m %>月</option>
            <% } %>
          </select>

          <select name="birthDay" required>
            <% for (let d = 1; d <= 31; d++) { %>
              <option value="<%= d %>"><%= d %>日</option>
            <% } %>
          </select>
        </div>
      </label>

      <button type="submit" class="clinic-main-button">
        次へ
      </button>

      <a class="clinic-sub-button" href="/psychiatry">
        戻る
      </a>

    </form>

  </div>
</div>

<%- include("partials/footer") %>