<%- include("partials/header", { title: "担当医選択" }) %>

<div class="admin-page">
  <div class="admin-card">

    <h1>担当医を選択</h1>

    <p class="admin-lead">
      予約を確認する担当医を選択してください。
    </p>

    <div class="doctor-list">
      <% doctors.forEach((doctor) => { %>
        <a
          href="/admin?doctorId=<%= doctor.id %>"
          class="doctor-card"
        >
          <p><%= doctor.displayName || doctor.name %></p>
          <span>＞</span>
        </a>
      <% }) %>
    </div>

  </div>
</div>

<%- include("partials/footer") %>