<%- include("partials/header", {
  title,
  isAdminPage,
  isAdminLoggedIn,
  doctor,
  doctors
}) %>

<%
  /*
   * 表示中の日付
   */
  const selectedDateText =
    typeof selectedDate === "string" &&
    /^\d{4}-\d{2}-\d{2}$/.test(selectedDate)
      ? selectedDate
      : today;

  const selectedDateObject =
    new Date(`${selectedDateText}T00:00:00+09:00`);

  const formattedSelectedDate =
    new Intl.DateTimeFormat("ja-JP", {
      timeZone: "Asia/Tokyo",
      month: "long",
      day: "numeric",
      weekday: "short"
    }).format(selectedDateObject);

  const formattedUpdatedAt =
    new Intl.DateTimeFormat("ja-JP", {
      timeZone: "Asia/Tokyo",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
      hour12: false
    }).format(updatedAt);

  /*
   * 現在の日本時間
   */
  const currentTime =
    new Intl.DateTimeFormat("ja-JP", {
      timeZone: "Asia/Tokyo",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false
    })
      .format(new Date())
      .replace("24:", "00:");

  /*
   * 日付をYYYY-MM-DD形式にする
   */
  const formatDateValue = (date) => {
    return new Intl.DateTimeFormat("sv-SE", {
      timeZone: "Asia/Tokyo",
      year: "numeric",
      month: "2-digit",
      day: "2-digit"
    }).format(date);
  };

  /*
   * 前日・翌日
   */
  const previousDateObject =
    new Date(selectedDateObject);

  previousDateObject.setDate(
    previousDateObject.getDate() - 1
  );

  const nextDateObject =
    new Date(selectedDateObject);

  nextDateObject.setDate(
    nextDateObject.getDate() + 1
  );

  const previousDate =
    formatDateValue(previousDateObject);

  const nextDate =
    formatDateValue(nextDateObject);

  const isToday =
    selectedDateText === today;

  const isPastDate =
    selectedDateText < today;

  /*
   * 「10:00〜11:00」や「10:00」から
   * 開始時刻だけ取得する
   */
  const getSlotStartTime = (slot) => {
    return String(slot || "")
      .split(/[〜～-]/)[0]
      .trim();
  };

  /*
   * 予約日をYYYY-MM-DD形式にする
   */
  const getReservationDateText = (
    reservationDate
  ) => {
    if (!reservationDate) {
      return "";
    }

    if (
      typeof reservationDate === "string" &&
      /^\d{4}-\d{2}-\d{2}/.test(
        reservationDate
      )
    ) {
      return reservationDate.slice(0, 10);
    }

    const date =
      new Date(reservationDate);

    if (Number.isNaN(date.getTime())) {
      return "";
    }

    return formatDateValue(date);
  };

  /*
   * 表示中の日付の予約だけ取得する
   */
  const selectedDateReservations =
    reservations.filter((reservation) => {
      return (
        getReservationDateText(
          reservation.date
        ) === selectedDateText
      );
    });

  /*
   * 表示日が今日の場合のみ、
   * 現在時刻以降の予約数を数える
   */
  const remainingReservationCount =
    isPastDate
      ? 0
      : selectedDateReservations.filter(
          (reservation) => {
            const startTime =
              getSlotStartTime(
                reservation.slot
              );

            if (!startTime) {
              return false;
            }

            if (!isToday) {
              return true;
            }

            return startTime >= currentTime;
          }
        ).length;

  /*
   * 各時間帯の最大定員
   */
  const maxCapacity =
    slots.length > 0
      ? Math.max(
          ...slots.map((slot) => {
            return getCapacityForSlot(
              selectedDateText,
              slot,
              doctorId
            );
          })
        )
      : 0;

  const circledNumbers = [
    "①",
    "②",
    "③",
    "④",
    "⑤",
    "⑥",
    "⑦",
    "⑧",
    "⑨",
    "⑩"
  ];

  const getPatientColumnLabel = (
    index
  ) => {
    return (
      circledNumbers[index] ||
      String(index + 1)
    );
  };
%>

<div class="admin-page-header">

  <div>
    <p class="admin-page-eyebrow">
      予約管理
    </p>

    <h1>
      日毎スケジュール
    </h1>
  </div>

</div>

<section class="admin-panel admin-date-search-panel">

  <div class="admin-date-navigation">

    <a
      class="admin-week-button"
      href="/admin?date=<%= encodeURIComponent(previousDate) %>"
    >
      ‹ 前日
    </a>

    <form
      class="admin-date-search-form"
      method="get"
      action="/admin"
    >

      <label for="admin-schedule-date">
        日付
      </label>

      <input
        id="admin-schedule-date"
        type="date"
        name="date"
        value="<%= selectedDateText %>"
        required
      >

      <button
        class="admin-primary-button"
        type="submit"
      >
        表示
      </button>

    </form>

    <a
      class="admin-week-button"
      href="/admin?date=<%= encodeURIComponent(nextDate) %>"
    >
      翌日 ›
    </a>

  </div>

  <% if (!isToday) { %>

    <div class="admin-today-link-row">

      <a
        class="admin-row-button"
        href="/admin?date=<%= encodeURIComponent(today) %>"
      >
        今日に戻る
      </a>

    </div>

  <% } %>

</section>

<section class="admin-panel admin-dashboard-panel">

  <div class="admin-dashboard-heading">

    <div>

      <h2>
        <%= formattedSelectedDate %>の予約状況
      </h2>

      <p class="admin-dashboard-doctor">
        担当医：
        <strong>
          <%= doctor.displayName || doctor.name %>
        </strong>
      </p>

    </div>

    <div class="admin-update-row">

      <span class="admin-updated-at">
        最終更新
        <strong>
          <%= formattedUpdatedAt %>
        </strong>
      </span>

      <button
        class="admin-refresh-button"
        type="button"
        onclick="location.reload()"
      >
        更新する
      </button>

    </div>

  </div>

  <% if (isPastDate) { %>

    <div
      class="admin-notice"
      role="status"
    >
      過去の日付です。予約内容の確認のみできます。
    </div>

  <% } %>

  <div class="admin-summary-row">

    <div class="admin-summary-item">

      <span class="admin-summary-label">
        <%= isToday ? "本日の予約" : "予約数" %>
      </span>

      <strong class="admin-summary-value">
        <%= selectedDateReservations.length %>
      </strong>

      <span class="admin-summary-unit">
        件
      </span>

    </div>

    <div class="admin-summary-item">

      <span class="admin-summary-label">
        <%= isToday
          ? "本日の残りの診療数"
          : isPastDate
            ? "残りの診療数"
            : "予定されている診療数"
        %>
      </span>

      <strong class="admin-summary-value">
        <%= remainingReservationCount %>
      </strong>

      <span class="admin-summary-unit">
        件
      </span>

    </div>

  </div>

  <div class="reservation-table-wrapper">

    <table
      class="
        reservation-table
        today-reservation-table
      "
    >

      <thead>
        <tr>

          <th class="today-time-column">
            時間
          </th>

          <% for (
            let index = 0;
            index < maxCapacity;
            index++
          ) { %>

            <th>
              患者<%= getPatientColumnLabel(index) %>
            </th>

          <% } %>

        </tr>
      </thead>

      <tbody>

        <% if (slots.length === 0) { %>

          <tr>
            <td
              colspan="<%= Math.max(maxCapacity + 1, 1) %>"
              class="admin-empty-message"
            >
              この日の診療予定はありません。
            </td>
          </tr>

        <% } else { %>

          <% slots.forEach((slot) => { %>

            <%
              const slotStartTime =
                getSlotStartTime(slot);

              /*
               * 過去日または今日の開始済み枠
               */
              const isPastSlot =
                isPastDate ||
                (
                  isToday &&
                  Boolean(slotStartTime) &&
                  slotStartTime < currentTime
                );

              const slotReservations =
                selectedDateReservations.filter(
                  (reservation) => {
                    return (
                      getSlotStartTime(
                        reservation.slot
                      ) === slotStartTime
                    );
                  }
                );

              const capacity =
                getCapacityForSlot(
                  selectedDateText,
                  slot,
                  doctorId
                );

              const slotUrl =
                `/admin/slot?doctorId=${encodeURIComponent(doctorId)}` +
                `&date=${encodeURIComponent(selectedDateText)}` +
                `&slot=${encodeURIComponent(slot)}`;
            %>

            <tr
              class="<%= isPastSlot
                ? 'is-past-slot-row'
                : ''
              %>"
            >

              <th
                class="
                  time-cell
                  <%= isPastSlot
                    ? 'is-reception-ended'
                    : ''
                  %>
                "
              >

                <a
                  class="today-time-link"
                  href="<%= slotUrl %>"
                  aria-label="<%= slot %>の予約枠詳細を開く"
                >
                  <%= slot %>
                </a>

              </th>

              <% for (
                let patientIndex = 0;
                patientIndex < maxCapacity;
                patientIndex++
              ) { %>

                <%
                  const reservation =
                    slotReservations[
                      patientIndex
                    ] || null;

                  const isAvailableColumn =
                    patientIndex < capacity;

                  const cellClass =
                    isPastSlot
                      ? "reception-ended-patient-cell"
                      : reservation
                        ? "reserved-patient-cell"
                        : isAvailableColumn
                          ? "empty-patient-cell"
                          : "unavailable-patient-cell";
                %>

                <td class="<%= cellClass %>">

                  <a
                    class="today-slot-link"
                    href="<%= slotUrl %>"
                    aria-label="<%= slot %>の予約枠詳細を開く"
                  >

                    <% if (isPastSlot) { %>

                      <% if (reservation) { %>

                        <span class="today-patient-name">
                          <%= reservation.patient.name %>
                        </span>

                        <span class="today-reception-ended-label">
                          受付終了
                        </span>

                      <% } else { %>

                        <span class="today-reception-ended-label">
                          受付終了
                        </span>

                      <% } %>

                    <% } else if (!isAvailableColumn) { %>

                      <span class="today-unavailable-label">
                        ―
                      </span>

                    <% } else if (reservation) { %>

                      <span class="today-patient-name">
                        <%= reservation.patient.name %>
                      </span>

                    <% } else { %>

                      <span class="today-empty-label">
                        空き
                      </span>

                    <% } %>

                    <span
                      class="today-cell-arrow"
                      aria-hidden="true"
                    >
                      ›
                    </span>

                  </a>

                </td>

              <% } %>

            </tr>

          <% }) %>

        <% } %>

      </tbody>

    </table>

  </div>

</section>

<%- include("partials/footer", {
  isAdminPage: true,
  isAdminLoggedIn
}) %>