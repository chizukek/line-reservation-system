<%- include("partials/header", {
  title,
  isAdminPage,
  isAdminLoggedIn,
  doctor,
  doctors
}) %>

<%
  const todayDate =
    new Date(`${today}T00:00:00+09:00`);

  const formattedToday =
    new Intl.DateTimeFormat("ja-JP", {
      timeZone: "Asia/Tokyo",
      month: "long",
      day: "numeric",
      weekday: "short"
    }).format(todayDate);

  const formattedUpdatedAt =
    new Intl.DateTimeFormat("ja-JP", {
      timeZone: "Asia/Tokyo",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
      hour12: false
    }).format(updatedAt);

  /*
   * 現在の日本時間をHH:MM形式で取得
   */
  const currentTime =
    new Intl.DateTimeFormat("ja-JP", {
      timeZone: "Asia/Tokyo",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false
    })
      .format(new Date())
      .replace("24:", "00:");

  /*
   * 「10:00〜11:00」や「10:00」から
   * 開始時刻の「10:00」だけを取得
   */
  const getSlotStartTime = (slot) => {
    return String(slot || "")
      .split(/[〜～-]/)[0]
      .trim();
  };

  /*
   * 予約日をYYYY-MM-DD形式にそろえる
   */
  const getReservationDateText = (
    reservationDate
  ) => {
    if (!reservationDate) {
      return "";
    }

    if (
      typeof reservationDate === "string" &&
      /^\d{4}-\d{2}-\d{2}/.test(
        reservationDate
      )
    ) {
      return reservationDate.slice(0, 10);
    }

    const date =
      new Date(reservationDate);

    if (Number.isNaN(date.getTime())) {
      return "";
    }

    return new Intl.DateTimeFormat(
      "sv-SE",
      {
        timeZone: "Asia/Tokyo",
        year: "numeric",
        month: "2-digit",
        day: "2-digit"
      }
    ).format(date);
  };

  /*
   * 今日の予約だけに限定
   */
  const todayReservations =
    reservations.filter((reservation) => {
      return (
        getReservationDateText(
          reservation.date
        ) === today
      );
    });

  /*
   * 現在時刻以降に開始する予約の人数
   */
  const remainingReservationCount =
    todayReservations.filter(
      (reservation) => {
        const startTime =
          getSlotStartTime(
            reservation.slot
          );

        return (
          startTime &&
          startTime >= currentTime
        );
      }
    ).length;

  /*
   * 本日の各時間帯のうち、
   * 最大の定員数を取得
   */
  const maxCapacity =
    slots.length > 0
      ? Math.max(
          ...slots.map((slot) => {
            return getCapacityForSlot(
              today,
              slot,
              doctorId
            );
          })
        )
      : 0;

  /*
   * 患者①、患者②の表示に使用
   */
  const circledNumbers = [
    "①",
    "②",
    "③",
    "④",
    "⑤",
    "⑥",
    "⑦",
    "⑧",
    "⑨",
    "⑩"
  ];

  const getPatientColumnLabel = (
    index
  ) => {
    return (
      circledNumbers[index] ||
      String(index + 1)
    );
  };
%>

<div class="admin-page-header">

  <div>
    <p class="admin-page-eyebrow">
      ダッシュボード
    </p>

    <h1>
      予約管理
    </h1>
  </div>

  <a
    class="admin-primary-button"
    href="/admin/add?doctorId=<%= doctorId %>"
  >
    予約を追加
  </a>

</div>

<section class="admin-panel admin-dashboard-panel">

  <div class="admin-dashboard-heading">

    <div>
      <h2>
        <%= formattedToday %>の予約状況
      </h2>

      <p class="admin-dashboard-doctor">
        担当医：
        <strong>
          <%= doctor.displayName || doctor.name %>
        </strong>
      </p>
    </div>

    <div class="admin-update-row">

      <span class="admin-updated-at">
        最終更新
        <strong>
          <%= formattedUpdatedAt %>
        </strong>
      </span>

      <button
        class="admin-refresh-button"
        type="button"
        onclick="location.reload()"
      >
        更新する
      </button>

    </div>

  </div>

  <div class="admin-summary-row">

    <div class="admin-summary-item">

      <span class="admin-summary-label">
        本日の予約
      </span>

      <strong class="admin-summary-value">
        <%= todayReservations.length %>
      </strong>

      <span class="admin-summary-unit">
        件
      </span>

    </div>

    <div class="admin-summary-item">

      <span class="admin-summary-label">
        本日の残りの診療数
      </span>

      <strong class="admin-summary-value">
        <%= remainingReservationCount %>
      </strong>

      <span class="admin-summary-unit">
        件
      </span>

    </div>

  </div>

  <div class="reservation-table-wrapper">

    <table
      class="
        reservation-table
        today-reservation-table
      "
    >

      <thead>
        <tr>

          <th class="today-time-column">
            時間
          </th>

          <% for (
            let index = 0;
            index < maxCapacity;
            index++
          ) { %>

            <th>
              患者<%= getPatientColumnLabel(index) %>
            </th>

          <% } %>

        </tr>
      </thead>

      <tbody>

        <% if (slots.length === 0) { %>

          <tr>
            <td
              colspan="<%= Math.max(maxCapacity + 1, 1) %>"
              class="admin-empty-message"
            >
              本日の診療予定はありません。
            </td>
          </tr>

        <% } else { %>

          <% slots.forEach((slot) => { %>

            <%
              const slotStartTime =
                getSlotStartTime(slot);

              /*
               * 開始時刻を過ぎた枠は受付終了
               */
              const isPastSlot =
                Boolean(slotStartTime) &&
                slotStartTime < currentTime;

              /*
               * この時間帯の予約だけを取得
               */
              const slotReservations =
                todayReservations.filter(
                  (reservation) => {
                    return (
                      getSlotStartTime(
                        reservation.slot
                      ) === slotStartTime
                    );
                  }
                );

              const capacity =
                getCapacityForSlot(
                  today,
                  slot,
                  doctorId
                );

              const slotUrl =
                `/admin/slot?doctorId=${doctorId}` +
                `&date=${today}` +
                `&slot=${encodeURIComponent(slot)}`;
            %>

            <tr
              class="<%= isPastSlot
                ? 'is-past-slot-row'
                : ''
              %>"
            >

              <th
                class="
                  time-cell
                  <%= isPastSlot
                    ? 'is-reception-ended'
                    : ''
                  %>
                "
              >

                <a
                  class="today-time-link"
                  href="<%= slotUrl %>"
                  aria-label="<%= slot %>の予約枠詳細を開く"
                >
                  <%= slot %>
                </a>

              </th>

              <% for (
                let patientIndex = 0;
                patientIndex < maxCapacity;
                patientIndex++
              ) { %>

                <%
                  const reservation =
                    slotReservations[
                      patientIndex
                    ] || null;

                  const isAvailableColumn =
                    patientIndex < capacity;

                  const cellClass =
                    isPastSlot
                      ? "reception-ended-patient-cell"
                      : reservation
                        ? "reserved-patient-cell"
                        : isAvailableColumn
                          ? "empty-patient-cell"
                          : "unavailable-patient-cell";
                %>

                <td class="<%= cellClass %>">

                  <a
                    class="today-slot-link"
                    href="<%= slotUrl %>"
                    aria-label="<%= slot %>の予約枠詳細を開く"
                  >

                    <% if (isPastSlot) { %>

                      <span
                        class="today-reception-ended-label"
                      >
                        受付終了
                      </span>

                    <% } else if (!isAvailableColumn) { %>

                      <span
                        class="today-unavailable-label"
                      >
                        ―
                      </span>

                    <% } else if (reservation) { %>

                      <span
                        class="today-patient-name"
                      >
                        <%= reservation.patient.name %>
                      </span>

                    <% } else { %>

                      <span
                        class="today-empty-label"
                      >
                        空き
                      </span>

                    <% } %>

                    <span
                      class="today-cell-arrow"
                      aria-hidden="true"
                    >
                      ›
                    </span>

                  </a>

                </td>

              <% } %>

            </tr>

          <% }) %>

        <% } %>

      </tbody>

    </table>

  </div>

</section>

<%- include("partials/footer", {
  isAdminPage: true,
  isAdminLoggedIn
}) %>