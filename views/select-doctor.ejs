<%- include("partials/header", { title: "担当医を選択" }) %>
<%- include("partials/progress", {
  step: 1
}) %>
<div class="clinic-page">
  <div class="clinic-card">

    <h1>
      <%= isChangeMode ? "変更先の担当医を選択してください" : "担当医を選択してください" %>
    </h1>

    <p class="clinic-description">
      ご希望の担当医を選択してください。
    </p>

    <div class="doctor-list">
      <% doctors.forEach((doctor) => { %>
        <a
          href="/reserve?doctorId=<%= doctor.id %>"
          class="doctor-card"
        >
          <strong><%= doctor.displayName || doctor.name %></strong>
          <span>＞</span>
        </a>
      <% }) %>
    </div>

    <div class="clinic-actions">
      <a
        class="clinic-sub-button"
        href="<%= isChangeMode ? '/mypage' : '/psychiatry' %>"
      >
        戻る
      </a>
    </div>

  </div>
</div>

<%- include("partials/footer") %>