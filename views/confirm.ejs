<%- include("partials/header", { title: "予約確認" }) %>
<%- include("partials/progress", { step: 3 }) %>

<h1>予約確認</h1>

<p>患者番号：<%= patient.patientNumber %></p>
<p>氏名：<%= patient.name %></p>
<p>予約日：<%= date %></p>
<p>予約時間：<%= slot %></p>

<form action="/reserve" method="POST">
  <input type="hidden" name="patientNumber" value="<%= patient.patientNumber %>">
  <input type="hidden" name="date" value="<%= date %>">
  <input type="hidden" name="slot" value="<%= slot %>">

  <button type="submit">この内容で予約する</button>
</form>

<br>

<a href="/">戻る</a>

<%- include("partials/footer") %>