<!DOCTYPE html>
<html lang="ja">

<head>
  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <title><%= title %></title>

  <link rel="stylesheet" href="/style.css">
</head>

<body>

<%
  const adminPage =
    typeof isAdminPage !== "undefined" &&
    isAdminPage;

  const adminLoggedIn =
    typeof isAdminLoggedIn !== "undefined" &&
    isAdminLoggedIn;

  const patientLoggedIn =
    typeof isPatientLoggedIn !== "undefined" &&
    isPatientLoggedIn;

  const selectedDoctor =
    typeof doctor !== "undefined"
      ? doctor
      : null;

  const availableDoctors =
    typeof doctors !== "undefined" &&
    Array.isArray(doctors)
      ? doctors
      : [];

  const currentDateTime =
    new Intl.DateTimeFormat("ja-JP", {
      timeZone: "Asia/Tokyo",
      year: "numeric",
      month: "long",
      day: "numeric",
      weekday: "short",
      hour: "2-digit",
      minute: "2-digit",
    }).format(new Date());
%>

<header
  class="site-header <%= adminPage
    ? 'admin-header-bar'
    : 'patient-header-bar'
  %>"
>

  <div class="site-header-inner">

    <a
      class="site-brand"
      href="<%= adminPage ? '/admin' : '/psychiatry' %>"
    >

      <div class="site-logo">
        <img
          src="/images/icon.png"
          alt="今村医院"
        >
      </div>

      <div class="site-brand-text">

        <div class="site-name">
          今村医院
        </div>

        <div class="site-subtitle">
          <%= adminPage
            ? "予約管理システム"
            : "心療内科再診予約"
          %>
        </div>

      </div>

    </a>

    <% if (adminPage && adminLoggedIn) { %>

      <div class="admin-header-actions">

        <time
          class="admin-current-datetime"
          id="admin-current-datetime"
        >
          <%= currentDateTime %>
        </time>

        <% if (selectedDoctor) { %>

          <details class="doctor-selector">

            <summary class="doctor-selector-button">

              <span>
                <%= selectedDoctor.displayName ||
                    selectedDoctor.name
                %>
              </span>

              <span
                class="doctor-selector-arrow"
                aria-hidden="true"
              >
                ▼
              </span>

            </summary>

            <div class="doctor-selector-menu">

              <% availableDoctors.forEach((doctorItem) => { %>

                <a
                  href="/admin?doctorId=<%= doctorItem.id %>"
                  class="doctor-selector-item <%= doctorItem.id === selectedDoctor.id
                    ? 'is-selected'
                    : ''
                  %>"
                >

                  <span>
                    <%= doctorItem.displayName ||
                        doctorItem.name
                    %>
                  </span>

                  <% if (doctorItem.id === selectedDoctor.id) { %>

                    <span
                      class="doctor-selector-check"
                      aria-label="選択中"
                    >
                      ✓
                    </span>

                  <% } %>

                </a>

              <% }) %>

            </div>

          </details>

        <% } else { %>

          <a
            class="doctor-selector-button"
            href="/admin/doctors"
          >
            医師を選択
          </a>

        <% } %>

        <a
          class="header-logout-link"
          href="/admin-logout"
        >
          ログアウト
        </a>

      </div>

    <% } else if (!adminPage && patientLoggedIn) { %>

      <nav class="site-nav patient-site-nav">

        <a href="/mypage">
          マイページ
        </a>

        <a href="/logout">
          ログアウト
        </a>

      </nav>

    <% } %>

  </div>

</header>

<% if (adminPage && adminLoggedIn) { %>

  <div class="admin-layout">

    <aside class="admin-sidebar">

      <nav class="admin-sidebar-nav">

        <div class="admin-sidebar-group">

          <p class="admin-sidebar-label">
            予約管理
          </p>

          <a
            href="/admin"
            class="admin-sidebar-link"
          >
            <span class="admin-sidebar-icon">⌂</span>
            <span>ダッシュボード</span>
          </a>

          <a
            href="/admin/reservations"
            class="admin-sidebar-link"
          >
            <span class="admin-sidebar-icon">▦</span>
            <span>予約スケジュール</span>
          </a>
          <a
            href="/admin/search"
            class="admin-sidebar-link"
          >
            <span class="admin-sidebar-icon">⌕</span>
            <span>予約検索</span>
          </a>

          <a
            href="/admin/add"
            class="admin-sidebar-link"
          >
            <span class="admin-sidebar-icon">＋</span>
            <span>予約追加</span>
          </a>

        </div>

        <div class="admin-sidebar-group">

          <p class="admin-sidebar-label">
            患者管理
          </p>

          <a
            href="/admin/patients"
            class="admin-sidebar-link"
          >
            <span class="admin-sidebar-icon">♙</span>
            <span>患者管理</span>
          </a>

        </div>

        <div class="admin-sidebar-group">

          <p class="admin-sidebar-label">
            その他
          </p>

          <a
            href="/admin/logs"
            class="admin-sidebar-link"
          >
            <span class="admin-sidebar-icon">☷</span>
            <span>操作ログ</span>
          </a>

        </div>

      </nav>

    </aside>

    <main class="admin-main">

<% } else { %>

  <main class="container">

<% } %>

<script>
  document.addEventListener("click", (event) => {
    document.querySelectorAll(".doctor-selector[open]").forEach((selector) => {
      if (!selector.contains(event.target)) {
        selector.removeAttribute("open");
      }
    });
  });
</script>