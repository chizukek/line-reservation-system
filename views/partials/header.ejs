<!DOCTYPE html>
<html lang="ja">

<head>
  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <title><%= title %></title>

  <link
    rel="stylesheet"
    href="/style.css"
  >
</head>

<body>

<%
  const adminPage =
    typeof isAdminPage !== "undefined" &&
    Boolean(isAdminPage);

  const adminLoggedIn =
    typeof isAdminLoggedIn !== "undefined" &&
    Boolean(isAdminLoggedIn);

  const patientLoggedIn =
    typeof isPatientLoggedIn !== "undefined" &&
    Boolean(isPatientLoggedIn);

  const selectedDoctor =
    typeof doctor !== "undefined" &&
    doctor
      ? doctor
      : null;

  const availableDoctors =
    typeof doctors !== "undefined" &&
    Array.isArray(doctors)
      ? doctors
      : [];

  const adminDoctorId =
    typeof doctorId !== "undefined" &&
    Number.isInteger(Number(doctorId))
      ? Number(doctorId)
      : selectedDoctor
        ? selectedDoctor.id
        : "";

  const adminCurrentPath =
    typeof path !== "undefined"
      ? String(path)
      : "";

  const adminSelectedDate =
    typeof selectedDate !== "undefined" &&
    selectedDate
      ? String(selectedDate)
      : typeof date !== "undefined" &&
          date
        ? String(date)
        : "";

  const currentDateTime =
    new Intl.DateTimeFormat("ja-JP", {
      timeZone: "Asia/Tokyo",
      year: "numeric",
      month: "long",
      day: "numeric",
      weekday: "short",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false
    })
      .format(new Date())
      .replace("24:", "00:");

  const buildDoctorSwitchUrl = (
    doctorItemId
  ) => {
    const params =
      new URLSearchParams();

    params.set(
      "doctorId",
      String(doctorItemId)
    );

    if (
      /^\d{4}-\d{2}-\d{2}$/.test(
        adminSelectedDate
      )
    ) {
      params.set(
        "date",
        adminSelectedDate
      );
    }

    return `/admin?${params.toString()}`;
  };
%>

<header
  class="site-header <%= adminPage
    ? 'admin-header-bar'
    : 'patient-header-bar'
  %>"
>

  <div class="site-header-inner">

    <a
      class="site-brand"
      href="<%= adminPage
        ? '/admin'
        : '/psychiatry'
      %>"
    >

      <div class="site-logo">

        <img
          src="/images/icon.png"
          alt="今村医院"
        >

      </div>

      <div class="site-brand-text">

        <div class="site-name">
          今村医院
        </div>

        <div class="site-subtitle">
          <%= adminPage
            ? "予約管理システム"
            : "心療内科再診予約"
          %>
        </div>

      </div>

    </a>

    <% if (
      adminPage &&
      adminLoggedIn
    ) { %>

      <div class="admin-header-actions">

        <time
          class="admin-current-datetime"
          id="admin-current-datetime"
        >
          <%= currentDateTime %>
        </time>

        <% if (selectedDoctor) { %>

          <details class="doctor-selector">

            <summary class="doctor-selector-button">

              <span>
                <%= selectedDoctor.displayName ||
                    selectedDoctor.name
                %>
              </span>

              <span
                class="doctor-selector-arrow"
                aria-hidden="true"
              >
                ▼
              </span>

            </summary>

            <div class="doctor-selector-menu">

              <% availableDoctors.forEach(
                (doctorItem) => {
              %>

                <a
                  href="<%= buildDoctorSwitchUrl(doctorItem.id) %>"
                  class="doctor-selector-item <%= doctorItem.id === selectedDoctor.id
                    ? 'is-selected'
                    : ''
                  %>"
                >

                  <span>
                    <%= doctorItem.displayName ||
                        doctorItem.name
                    %>
                  </span>

                  <% if (
                    doctorItem.id ===
                    selectedDoctor.id
                  ) { %>

                    <span
                      class="doctor-selector-check"
                      aria-label="選択中"
                    >
                      ✓
                    </span>

                  <% } %>

                </a>

              <% }) %>

            </div>

          </details>

        <% } else { %>

          <a
            class="doctor-selector-button"
            href="/admin/doctors"
          >
            医師を選択
          </a>

        <% } %>

        <a
          class="header-logout-link"
          href="/admin-logout"
        >
          ログアウト
        </a>

      </div>

    <% } else if (
      !adminPage &&
      patientLoggedIn
    ) { %>

      <nav
        class="site-nav patient-site-nav"
        aria-label="患者メニュー"
      >

        <a href="/mypage">
          マイページ
        </a>

      </nav>

    <% } %>

  </div>

</header>

<% if (
  adminPage &&
  adminLoggedIn
) { %>

  <div class="admin-layout">

    <%- include("admin-side-menu", {
      doctorId: adminDoctorId,
      doctor: selectedDoctor,
      doctors: availableDoctors,
      path: adminCurrentPath,
      date: adminSelectedDate
    }) %>

    <main class="admin-main">

<% } else { %>

  <main class="container">

<% } %>

<script>
  document.addEventListener(
    "click",
    (event) => {
      document
        .querySelectorAll(
          ".doctor-selector[open]"
        )
        .forEach((selector) => {
          if (
            !selector.contains(
              event.target
            )
          ) {
            selector.removeAttribute(
              "open"
            );
          }
        });
    }
  );
</script>