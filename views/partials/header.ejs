<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<%
const isAdminPage =
  typeof title !== "undefined" &&
  (
    title.includes("管理") ||
    title.includes("予約一覧") ||
    title.includes("電話予約") ||
    title.includes("患者")
  );
%>

<header class="<%= isAdminPage ? 'site-header admin-header-bar' : 'site-header' %>">

  <div class="site-header-inner">

    <a class="site-brand" href="<%= isAdminPage ? '/admin' : '/psychiatry' %>">

      <div class="site-logo">
        <img src="/images/icon.png" alt="〇〇クリニック">
      </div>

      <div class="site-brand-text">
        <div class="site-name">
          今村医院
        </div>

        <div class="site-subtitle">
          <%= isAdminPage ? "予約管理システム" : "心療内科再診予約" %>
        </div>
      </div>

    </a>

    <nav class="site-nav">
      <% if (isAdminPage && isAdminLoggedIn) { %>
        <a href="/admin">予約一覧</a>
        <a href="/admin/patients">患者管理</a>
        <a href="/admin-logout">ログアウト</a>
      <% } else if (!isAdminPage && isPatientLoggedIn) { %>
        <a href="/mypage">マイページ</a>
        <a href="/logout">ログアウト</a>
      <% } %>
    </nav>

  </div>

</header>

<div class="container">