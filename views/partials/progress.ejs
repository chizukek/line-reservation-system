<div class="progress">

  <div class="progress-step <%= step >= 1 ? 'active' : '' %>">
    <div class="circle">1</div>
    <div class="label">担当医</div>
  </div>

  <div class="line <%= step >= 2 ? 'active' : '' %>"></div>

  <div class="progress-step <%= step >= 2 ? 'active' : '' %>">
    <div class="circle">2</div>
    <div class="label">日時選択</div>
  </div>

  <div class="line <%= step >= 3 ? 'active' : '' %>"></div>

  <div class="progress-step <%= step >= 3 ? 'active' : '' %>">
    <div class="circle">3</div>
    <div class="label">確認</div>
  </div>

  <div class="line <%= step >= 4 ? 'active' : '' %>"></div>

  <div class="progress-step <%= step >= 4 ? 'active' : '' %>">
    <div class="circle">4</div>
    <div class="label">完了</div>
  </div>

</div>