<%
  const footerAdminPage =
    typeof isAdminPage !== "undefined" &&
    isAdminPage;

  const footerAdminLoggedIn =
    typeof isAdminLoggedIn !== "undefined" &&
    isAdminLoggedIn;
%>

<% if (footerAdminPage && footerAdminLoggedIn) { %>

    </main>
  </div>

<% } else { %>

  </main>

<% } %>

<script>
  const dateTimeElement =
    document.getElementById("admin-current-datetime");

  function updateAdminDateTime() {
    if (!dateTimeElement) {
      return;
    }

    const now = new Date();

    dateTimeElement.textContent =
      new Intl.DateTimeFormat("ja-JP", {
        timeZone: "Asia/Tokyo",
        year: "numeric",
        month: "long",
        day: "numeric",
        weekday: "short",
        hour: "2-digit",
        minute: "2-digit",
      }).format(now);
  }

  updateAdminDateTime();
  setInterval(updateAdminDateTime, 30000);
</script>

</body>
</html>