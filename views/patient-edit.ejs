<%- include("partials/header", { title: "患者編集" }) %>

<div class="admin-page">
  <div class="admin-card">

    <h1>患者編集</h1>

    <% if (error) { %>
      <div class="clinic-error">
        <%= error %>
      </div>
    <% } %>

    <form action="/admin/patients/edit/<%= patient.id %>" method="POST" class="admin-form-card">

      <label>
        <span>患者番号</span>
        <input
          type="text"
          name="patientNumber"
          value="<%= patient.patientNumber %>"
          inputmode="numeric"
          required
        >
      </label>

      <label>
        <span>氏名</span>
        <input
          type="text"
          name="name"
          value="<%= patient.name %>"
          required
        >
      </label>

      <label>
        <span>生年月日</span>

        <div class="birth-select">
          <select name="birthYear" required>
  <% for (let y = currentYear; y >= 1900; y--) { %>
    <option value="<%= y %>" <%= y === birthYear ? "selected" : "" %>>
      <%= y %>年
    </option>
  <% } %>
</select>

<select name="birthMonth" required>
  <% for (let m = 1; m <= 12; m++) { %>
    <option value="<%= m %>" <%= m === birthMonth ? "selected" : "" %>>
      <%= m %>月
    </option>
  <% } %>
</select>

<select name="birthDay" required>
  <% for (let d = 1; d <= 31; d++) { %>
    <option value="<%= d %>" <%= d === birthDay ? "selected" : "" %>>
      <%= d %>日
    </option>
  <% } %>
</select>
        </div>
      </label>

      <div class="clinic-actions">
        <button class="clinic-main-button" type="submit">
          保存する
        </button>

        <a class="clinic-sub-button" href="/admin/patients">
          戻る
        </a>
      </div>

    </form>

  </div>
</div>

<%- include("partials/footer") %>