<%- include("partials/header", {
  title
}) %>

<div class="admin-page admin-complete-page">
  <div class="admin-card">

    <section class="admin-panel admin-complete-panel">

      <div
        class="admin-complete-icon"
        aria-hidden="true"
      >
        ✓
      </div>

      <p class="admin-page-eyebrow">
        処理完了
      </p>

      <h1>
        <%= title %>
      </h1>

      <p class="admin-complete-message">
        <%= message %>
      </p>

      <div class="admin-complete-actions">

        <a
          class="admin-primary-button"
          href="<%= buttonLink %>"
        >
          <%= buttonText %>
        </a>

        <a
          class="admin-week-button"
          href="/admin"
        >
          本日の予約へ
        </a>

      </div>

    </section>

  </div>
</div>

<%- include("partials/footer") %>