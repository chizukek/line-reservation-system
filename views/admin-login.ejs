<%- include("partials/header", { title: "管理者ログイン" }) %>

<div class="admin-page">
  <div class="admin-card admin-login-card">

    <h1>予約管理システム</h1>

    <p class="clinic-lead">
      管理者専用ページです。<br>
      パスワードを入力してください。
    </p>

    <% if (error) { %>
      <div class="clinic-error">
        <%= error %>
      </div>
    <% } %>

    <form action="/admin-login" method="POST" class="admin-form-card">

      <label>
        <span>パスワード</span>

        <input
          type="password"
          name="password"
          placeholder="パスワード"
          required
        >
      </label>

      <button class="clinic-main-button" type="submit">
        ログイン
      </button>

    </form>

  </div>
</div>

<%- include("partials/footer") %>