<%- include("partials/header", { title: "患者削除確認" }) %>

<div class="admin-page">
  <div class="admin-card">

    <h1>患者削除確認</h1>

    <section class="admin-section">
      <h2>患者情報</h2>

      <div class="reservation-box">

        <div class="info-row">
          <span>患者番号</span>
          <strong><%= patient.patientNumber %></strong>
        </div>

        <div class="info-row">
          <span>氏名</span>
          <strong><%= patient.name %> 様</strong>
        </div>

      </div>
    </section>

    <div class="clinic-error">
      この患者情報を削除します。<br>
      この操作は取り消せません。
    </div>

    <form
      action="/admin/patients/delete/<%= patient.id %>"
      method="POST"
      class="clinic-actions"
    >

      <button
        type="submit"
        class="admin-danger-button"
      >
        削除する
      </button>

      <a
        href="/admin/patients"
        class="clinic-sub-button"
      >
        戻る
      </a>

    </form>

  </div>
</div>

<%- include("partials/footer") %>