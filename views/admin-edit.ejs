<%- include("partials/header", {
  title: "予約変更",
  isAdminPage: true,
  isAdminLoggedIn
}) %>

<div class="admin-page">
  <div class="admin-card">

    <header class="admin-page-header">
      <div>
        <p class="admin-page-eyebrow">
          予約管理
        </p>

        <h1>
          予約変更
        </h1>

        <p class="admin-page-description">
          変更後の日時を選択してください。
        </p>
      </div>
    </header>

    <% if (error) { %>
      <div
        class="clinic-error"
        role="alert"
      >
        <%= error %>
      </div>
    <% } %>

    <section class="admin-section">

      <h2>
        現在の予約
      </h2>

      <table class="admin-info-table">
  <thead>
    <tr>
      <th>予約日</th>
      <th>時間</th>
      <th>担当医</th>
      <th>患者番号</th>
      <th>患者氏名</th>
    </tr>
  </thead>

  <tbody>
    <tr>
      <td>
        <%= formatJapaneseDate(reservation.date) %>
      </td>

      <td>
        <%= getSlotLabel(reservation.slot, doctorId) %>
      </td>

      <td>
        <%= doctor.displayName || doctor.name %>
      </td>

      <td>
        <%= reservation.patientNumber %>
      </td>

      <td>
        <strong>
          <%= reservation.patient.name %> 様
        </strong>
      </td>
    </tr>
  </tbody>
</table>

    </section>

    <section class="admin-section">

      <h2>
        変更後の内容
      </h2>

      <form
  action="/admin/edit/<%= reservation.id %>/confirm"
  method="POST"
  class="admin-form-card"
  id="reservation-edit-form"
  data-doctor-id="<%= doctorId %>"
  data-reservation-id="<%= reservation.id %>"
  data-current-slot="<%= reservation.slot %>"
>

        <input
          type="hidden"
          name="doctorId"
          value="<%= doctorId %>"
        >

        <label>
          <span>
            変更後の日付
          </span>

          <input
            type="date"
            id="date"
            name="date"
            value="<%= reservation.date %>"
            required
          >
        </label>

        <label>
          <span>
            変更後の時間
          </span>

          <select
            id="slot"
            name="slot"
            required
          >
            <% slots.forEach((slot) => { %>

              <option
                value="<%= slot %>"
                <%= slot === reservation.slot
                  ? "selected"
                  : ""
                %>
              >
                <%= getSlotLabel(slot, doctorId) %>
              </option>

            <% }) %>
          </select>
        </label>

        <p
          id="slot-message"
          class="admin-form-message"
          aria-live="polite"
          hidden
        ></p>

        <div class="clinic-actions">

          <button
            class="clinic-main-button"
            id="submit-button"
            type="submit"
          >
            変更内容を確認する
          </button>

          <a
            class="clinic-sub-button"
            href="/admin/reservations"
          >
            戻る
          </a>

        </div>

      </form>

    </section>

  </div>
</div>

<script>
  const form =
    document.getElementById("reservation-edit-form");

  const dateInput =
    document.getElementById("date");

  const slotSelect =
    document.getElementById("slot");

  const slotMessage =
    document.getElementById("slot-message");

  const submitButton =
    document.getElementById("submit-button");

  const doctorId =
    form.dataset.doctorId;

  const reservationId =
    form.dataset.reservationId;

  let selectedSlot =
    form.dataset.currentSlot;

  function showMessage(message) {
    slotMessage.textContent = message;
    slotMessage.hidden = !message;
  }

  function showEmptyOption(message) {
    slotSelect.innerHTML = "";

    const option =
      document.createElement("option");

    option.value = "";
    option.textContent = message;

    slotSelect.appendChild(option);
  }

  function setLoading(isLoading) {
    slotSelect.disabled = isLoading;
    submitButton.disabled = isLoading;

    if (isLoading) {
      showMessage(
        "予約可能な時間を読み込んでいます。",
      );
    }
  }

  async function loadSlots({
    preserveCurrentSlot = false,
  } = {}) {
    const date = dateInput.value;

    if (!date) {
      showEmptyOption(
        "日付を選択してください",
      );

      slotSelect.disabled = true;
      submitButton.disabled = true;

      showMessage(
        "変更後の日付を選択してください。",
      );

      return;
    }

    setLoading(true);

    try {
      const params =
        new URLSearchParams({
          date,
          doctorId,
          excludeReservationId:
            reservationId,
        });

      const response =
        await fetch(
          `/api/admin/slots?${params.toString()}`,
          {
            method: "GET",
            headers: {
              Accept: "application/json",
            },
          },
        );

      if (!response.ok) {
        throw new Error(
          `HTTPエラー: ${response.status}`,
        );
      }

      const result =
        await response.json();

      const slots =
        Array.isArray(result)
          ? result
          : result.slots;

      if (!Array.isArray(slots)) {
        throw new Error(
          "予約枠の形式が正しくありません。",
        );
      }

      if (slots.length === 0) {
        showEmptyOption(
          "予約可能な時間がありません",
        );

        slotSelect.disabled = true;
        submitButton.disabled = true;

        showMessage(
          "この日に予約可能な時間はありません。",
        );

        return;
      }

      slotSelect.innerHTML = "";

      let selectedSlotExists = false;

      slots.forEach((slotItem) => {
        const value =
          typeof slotItem === "string"
            ? slotItem
            : slotItem.value;

        const label =
          typeof slotItem === "string"
            ? slotItem
            : slotItem.label || slotItem.value;

        if (!value) {
          return;
        }

        const option =
          document.createElement("option");

        option.value = value;
        option.textContent = label;

        if (
          preserveCurrentSlot &&
          value === selectedSlot
        ) {
          option.selected = true;
          selectedSlotExists = true;
        }

        slotSelect.appendChild(option);
      });

      if (
        preserveCurrentSlot &&
        !selectedSlotExists
      ) {
        selectedSlot =
          slotSelect.value;
      }

      if (!preserveCurrentSlot) {
        selectedSlot =
          slotSelect.value;
      }

      slotSelect.disabled = false;
      submitButton.disabled = false;

      showMessage("");
    } catch (error) {
      console.error(
        "予約可能時間取得エラー:",
        error,
      );

      showEmptyOption(
        "予約時間を取得できませんでした",
      );

      slotSelect.disabled = true;
      submitButton.disabled = true;

      showMessage(
        "予約時間を取得できませんでした。ページを再読み込みしてください。",
      );
    }
  }

  dateInput.addEventListener(
    "change",
    () => {
      selectedSlot = "";

      loadSlots({
        preserveCurrentSlot: false,
      });
    },
  );

  slotSelect.addEventListener(
    "change",
    () => {
      selectedSlot =
        slotSelect.value;
    },
  );

  form.addEventListener(
    "submit",
    (event) => {
      if (
        !dateInput.value ||
        !slotSelect.value ||
        slotSelect.disabled
      ) {
        event.preventDefault();

        showMessage(
          "予約可能な日時を選択してください。",
        );
      }
    },
  );

  if (dateInput.value) {
    loadSlots({
      preserveCurrentSlot: true,
    });
  }
</script>

<%- include("partials/footer", {
  isAdminPage: true,
  isAdminLoggedIn
}) %>