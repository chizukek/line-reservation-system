<%- include("partials/header", { title: "予約変更" }) %>

<div class="admin-page">
  <div class="admin-card">

    <h1>予約変更</h1>

    <% if (error) { %>
      <div class="clinic-error">
        <%= error %>
      </div>
    <% } %>

    <section class="admin-section">
      <h2>現在の予約</h2>

      <div class="reservation-box">
        <div class="info-row">
          <span>患者番号</span>
          <strong><%= reservation.patientNumber %></strong>
        </div>

        <div class="info-row">
          <span>氏名</span>
          <strong><%= reservation.patient.name %> 様</strong>
        </div>

        <div class="info-row">
          <span>予約日</span>
          <strong><%= reservation.date %></strong>
        </div>

        <div class="info-row">
          <span>時間</span>
          <strong><%= reservation.slot %></strong>
        </div>
      </div>
    </section>

    <section class="admin-section">
      <h2>変更後の内容</h2>

      <form action="/admin/edit/<%= reservation.id %>" method="POST" class="admin-form-card">
        <label>
          <span>変更後の日付</span>
          <input type="date" id="date" name="date" value="<%= reservation.date %>" required>
        </label>

        <label>
          <span>変更後の時間</span>
          <select id="slot" name="slot" required>
  <% slots.forEach(slot => { %>
    <option
      value="<%= slot %>"
      <%= slot === reservation.slot ? "selected" : "" %>>
      <%= slot %>
    </option>
  <% }) %>
</select>
        </label>

        <div class="clinic-actions">
          <button class="clinic-main-button" type="submit">
            変更する
          </button>

          <a class="clinic-sub-button" href="/admin">
            戻る
          </a>
        </div>
      </form>
    </section>

  </div>
</div>

<script>
const dateInput = document.getElementById("date");
const slotSelect = document.getElementById("slot");

// 現在選択中の時間を保持
let currentSlot = slotSelect.value;

async function loadSlots() {
  const date = dateInput.value;

  if (!date) return;

  const res = await fetch("/api/slots?date=" + date);
  const slots = await res.json();

  slotSelect.innerHTML = "";

  slots.forEach(slot => {
    const option = document.createElement("option");
    option.value = slot;
    option.textContent = slot;

    // 元の時間があれば選択状態を維持
    if (slot === currentSlot) {
      option.selected = true;
    }

    slotSelect.appendChild(option);
  });

  // 新しい日付に現在の時間が無い場合は先頭を選択
  currentSlot = slotSelect.value;
}

dateInput.addEventListener("change", loadSlots);

if (dateInput.value) {
  loadSlots();
}
</script>

<%- include("partials/footer") %>