<%- include("partials/header", { title: "予約一覧" }) %>

<div class="admin-page">
  <div class="admin-card">
    <div class="admin-header">
      <div>
        <h1>予約管理</h1>
        <p>予約一覧・電話予約・患者管理</p>
      </div>
    </div>

    <div class="admin-menu">
      <a class="admin-menu-item" href="/admin/add">
        <span>電話予約を追加</span>
        <strong>＞</strong>
      </a>

      <a class="admin-menu-item" href="/admin/patients">
        <span>患者管理</span>
        <strong>＞</strong>
      </a>
    </div>

    <section class="admin-section">
      <h2>予約検索</h2>

      <form method="GET" action="/admin" class="admin-search-form">
        <label>
          <span>日付</span>
          <input type="date" name="date" value="<%= searchDate %>">
        </label>

        <label>
          <span>患者番号</span>
          <input
            type="text"
            name="patientNumber"
            placeholder="例：10001"
            value="<%= searchPatientNumber %>"
            maxlength="5"
inputmode="numeric"
autocomplete="off"
          >
        </label>

        <button type="submit" class="clinic-main-button">
          検索する
        </button>
      </form>

      <div class="admin-filter-links">
        <a href="/admin?date=<%= today %>">今日の予約</a>
        <a href="/admin">全件表示</a>
      </div>

      <p class="admin-result-text">
        検索中の患者番号：<strong><%= searchPatientNumber || "なし" %></strong><br>
        検索結果：<strong><%= reservations.length %>件</strong>
      </p>
    </section>

    <section class="admin-section">
      <h2>予約一覧</h2>

      <% if (reservations.length === 0) { %>
        <div class="admin-empty">
          該当する予約はありません。
        </div>
      <% } else { %>
        <div class="admin-table-wrapper">
          <table class="admin-table">
            <thead>
  <tr>
    <th>日時</th>
    <th>氏名</th>
    <th>患者番号</th>
    <th>操作</th>
  </tr>
</thead>

<tbody>
  <% reservations.forEach(r => { %>
    <tr>
      <td>
        <strong><%= r.date %></strong><br>
        <%= r.slot %>
      </td>
      <td><%= r.patient.name %></td>
      <td><%= r.patientNumber %></td>
      <td>
        <div class="admin-action-buttons">
          <a class="admin-small-button" href="/admin/edit/<%= r.id %>">
            変更
          </a>

          <a class="admin-danger-button" href="/admin/cancel-confirm/<%= r.id %>">
  キャンセル
</a>
        </div>
      </td>
    </tr>
  <% }) %>
</tbody>
          </table>
        </div>
      <% } %>
    </section>
  </div>
</div>

<%- include("partials/footer") %>