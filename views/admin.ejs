<%- include("partials/header", { title: "予約一覧" }) %>

<div class="admin-page">
  <div class="admin-card">

    <div class="admin-header">
      <div>
        <h1>予約管理</h1>
        <p>
          担当医：<strong><%= doctor.displayName || doctor.name %></strong>
        </p>
      </div>
    </div>

    <div class="admin-layout">

      <main class="admin-main">
  <section class="admin-section">
    <h2>一週間の予約空き状況</h2>

    <div class="reserve-legend">
      <span><span class="mark-open">○</span> 受付可能</span>
      <span><span class="mark-partial">△</span> 残りわずか</span>
      <span><span class="mark-full">満</span> 満員</span>
      <span><span class="mark-disabled">−</span> 受付不可</span>
    </div>

    <div class="week-nav">
      <a
        class="week-btn"
        href="/admin/reservations?doctorId=<%= doctorId %>&week=<%= Math.max(0, week - 1) %>"
      >
        ‹ 前の7日間
      </a>

      <% if (canGoNextWeek) { %>
        <a
          class="week-btn active"
          href="/admin/reservations?doctorId=<%= doctorId %>&week=<%= week + 1 %>"
        >
          次の7日間 ›
        </a>
      <% } else { %>
        <span class="week-btn disabled">
          次の7日間 ›
        </span>
      <% } %>
    </div>

    <div class="reservation-table-wrapper">
      <table class="reservation-table">

        <tr class="month-row">
          <th></th>

          <%
            let currentMonth = "";
            let monthStart = 0;
            const monthGroups = [];

            dates.forEach((date, index) => {
              const monthText = date.value.slice(0, 7);

              if (monthText !== currentMonth) {
                if (currentMonth) {
                  monthGroups.push({
                    month: currentMonth,
                    colspan: index - monthStart
                  });
                }

                currentMonth = monthText;
                monthStart = index;
              }
            });

            monthGroups.push({
              month: currentMonth,
              colspan: dates.length - monthStart
            });
          %>

          <% monthGroups.forEach(group => { %>
            <th colspan="<%= group.colspan %>">
              <%= group.month.replace("-", "年") %>月
            </th>
          <% }) %>
        </tr>

        <tr class="date-row">
          <th>日時</th>

          <% dates.forEach(date => {
            const d = new Date(date.value);
            const day = d.getDate();
            const weekday = ["日", "月", "火", "水", "木", "金", "土"][d.getDay()];
            const dayClass = d.getDay() === 0 ? "sunday" : d.getDay() === 6 ? "saturday" : "";
          %>
            <th class="<%= dayClass %>">
              <div><%= day %></div>
              <div>(<%= weekday %>)</div>
            </th>
          <% }) %>
        </tr>

        <% slots.forEach(slot => { %>
          <tr>
            <th class="time-cell">
              <%= getSlotLabel(slot, doctorId) %>
            </th>

            <% dates.forEach(date => { %>
              <%
  const count = reservations.filter(
    r => r.date === date.value && r.slot === slot
  ).length;

  const availableSlots = getSlotsForDate(date.value, doctorId);
  const capacity = getCapacityForSlot(date.value, slot, doctorId);

  let cellClass = "";
  let mark = "";
  let href = "";

  if (!availableSlots.includes(slot)) {
    cellClass = "unavailable-cell";
    mark = "−";
  } else if (date.value <= today) {
    cellClass = "unavailable-cell";
    mark = "−";
  } else if (date.value > maxReservableText) {
    cellClass = "unavailable-cell";
    mark = "−";
  } else {
    href =
      `/admin/slot?doctorId=${doctorId}` +
      `&date=${date.value}` +
      `&slot=${encodeURIComponent(slot)}`;

    if (count >= capacity) {
      cellClass = "full-cell";
      mark = "満";
    } else if (count > 0) {
      cellClass = "open-cell";
      mark = "△";
    } else {
      cellClass = "open-cell";
      mark = "○";
    }
  }
%>

              <td class="<%= cellClass %>">
  <% if (href) { %>
    <a class="slot-link" href="<%= href %>">
      <% if (mark === "○") { %>
        <span class="mark-open">○</span>
      <% } else if (mark === "△") { %>
        <span class="mark-partial">△</span>
      <% } else if (mark === "満") { %>
        <span class="mark-full">満</span>
      <% } %>
    </a>
  <% } else { %>
    <span class="mark-disabled">−</span>
  <% } %>
</td>
            <% }) %>
          </tr>
        <% }) %>

      </table>
    </div>
  </section>
</main>

      <aside class="admin-side">
  <div class="admin-side-card">
    <h2>操作メニュー</h2>

    <a
  class="admin-side-link"
  href="/admin/reservations?doctorId=<%= doctorId %>"
>
  予約スケジュール
</a>

<a
  class="admin-side-link"
  href="/admin/search"
>
  検索
</a>

<a
  class="admin-side-link"
  href="/admin/logs"
>
  操作ログ
</a>
  </div>
</aside>

    </div>

  </div>
</div>

<%- include("partials/footer") %>