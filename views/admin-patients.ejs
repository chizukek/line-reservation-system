<%- include("partials/header", {
  title: "患者管理",
  isAdminPage: true,
  isAdminLoggedIn: true,
  doctorId,
  doctor,
  doctors,
  path
}) %>

<%
  const getDoctorColorClass = (
    reservation
  ) => {
    if (
      !reservation ||
      !reservation.doctor
    ) {
      return "";
    }

    /*
     * 医師IDで判定する場合
     * 医師AがID 1、医師BがID 2という前提
     */
    if (reservation.doctor.id === 1) {
      return "color_A";
    }

    if (reservation.doctor.id === 2) {
      return "color_B";
    }

    return "";
  };

  const getReservationDateTime = (
    reservation
  ) => {
    if (!reservation) {
      return "予約なし";
    }

    const dateLabel =
      formatJapaneseDateShort(
        reservation.date
      );

    return `${dateLabel} ${reservation.slot}`;
  };
%>

<div class="admin-page">
  <div class="admin-card">

    <header class="admin-page-header">

      <div>
        <p class="admin-page-eyebrow">
          患者管理
        </p>

        <h1>
          患者管理
        </h1>

        <p class="admin-page-description">
          患者番号または氏名で検索してください。
        </p>
      </div>

      <a
        class="admin-primary-button"
        href="/admin/patients/add"
      >
        ＋ 新規登録
      </a>

    </header>

    <section class="admin-panel">

      <h2 class="admin-panel-title">
        患者検索
      </h2>

      <form
        class="admin-search-form"
        action="/admin/patients"
        method="get"
      >

        <label class="admin-search-field">

          <span>
            患者番号または氏名
          </span>

          <input
            type="search"
            name="keyword"
            value="<%= keyword || "" %>"
            placeholder="例：12345 または 山田"
            autocomplete="off"
          >

        </label>

        <button
          class="admin-primary-button"
          type="submit"
        >
          検索
        </button>

      </form>

    </section>

    <% if (keyword) { %>

      <section class="admin-panel">

        <div class="admin-section-title-row">

          <h2 class="admin-panel-title">
            検索結果
          </h2>

          <span class="admin-result-count">
            <%= patients.length %>件
          </span>

        </div>

        <% if (patients.length === 0) { %>

          <div class="admin-empty">
            「<%= keyword %>」に一致する患者はいません。
          </div>

        <% } else { %>

          <div class="admin-table-wrapper">

  <table class="admin-table admin-patient-table">

    <thead>
      <tr>
        <th>患者番号</th>
        <th>患者名</th>
        <th>現在の予約日時</th>
        <th>操作</th>
      </tr>
    </thead>

    <tbody>

      <% patients.forEach((patient) => { %>

        <%
          const reservation =
            patient.reservations?.[0] || null;

          let doctorClass = "";

          if (reservation) {
            if (reservation.doctorId === 1) {
              doctorClass = "color_A";
            } else if (reservation.doctorId === 2) {
              doctorClass = "color_B";
            }
          }
        %>

        <tr>

          <td>
            <strong>
              <%= patient.patientNumber %>
            </strong>
          </td>

          <td>
            <%= patient.name %>
          </td>

          <td>

            <% if (reservation) { %>

              <div class="admin-patient-reservation">

                <span
                  class="admin-doctor-dot <%= doctorClass %>"
                  aria-hidden="true"
                ></span>

                <span>
                  <%= formatJapaneseDateShort(reservation.date) %>
                  <%= reservation.slot %>
                </span>

              </div>

            <% } else { %>

              <span class="admin-no-reservation">
                予約なし
              </span>

            <% } %>

          </td>

          <td>

            <a
              class="admin-row-button"
              href="/admin/patients/edit/<%= patient.id %>"
            >
              編集
            </a>

          </td>

        </tr>

      <% }) %>

    </tbody>

  </table>

</div>

        <% } %>

      </section>

    <% } else { %>

      <div class="admin-empty">
        検索条件を入力すると、患者情報が表示されます。
      </div>

    <% } %>

  </div>
</div>

<%- include("partials/footer", {
  isAdminPage: true,
  isAdminLoggedIn: true
}) %>