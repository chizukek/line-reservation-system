<%- include("partials/header", { title: "患者登録" }) %>

<div class="admin-page">
  <div class="admin-card">

    <h1>患者登録</h1>

    <p class="clinic-lead">
      新しい患者を登録します。
    </p>

    <% if (error) { %>
      <div class="clinic-error">
        <%= error %>
      </div>
    <% } %>

    <form action="/admin/patients/add" method="POST" class="admin-form-card">

      <label>
        <span>患者番号</span>
        <input
          type="text"
          name="patientNumber"
          inputmode="numeric"
          autocomplete="off"
          placeholder="例：10001"
          required
        >
      </label>

      <label>
        <span>氏名</span>
        <input
          type="text"
          name="name"
          placeholder="例：山田 太郎"
          required
        >
      </label>

      <label>
        <span>生年月日</span>
        <input
          type="date"
          name="birthDate"
          required
        >
      </label>

      <div class="clinic-actions">
        <button class="clinic-main-button" type="submit">
          患者を登録する
        </button>

        <a class="clinic-sub-button" href="/admin/patients">
          戻る
        </a>
      </div>

    </form>

  </div>
</div>

<%- include("partials/footer") %>