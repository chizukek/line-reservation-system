<%- include("partials/header", {
  title: "予約スケジュール",
  isAdminPage: true,
  isAdminLoggedIn,
  doctor,
  doctors
}) %>

<%
  const changeReservation =
    typeof editReservation !== "undefined"
      ? editReservation
      : null;

  const changeReservationId =
    changeReservation
      ? Number(changeReservation.id)
      : 0;

  const isEditMode =
    Number.isInteger(changeReservationId) &&
    changeReservationId > 0;

  /*
   * 日付をYYYY-MM-DD形式にそろえる
   */
  const getDateText = (value) => {
    if (!value) {
      return "";
    }

    if (
      typeof value === "string" &&
      /^\d{4}-\d{2}-\d{2}/.test(value)
    ) {
      return value.slice(0, 10);
    }

    const dateObject = new Date(value);

    if (Number.isNaN(dateObject.getTime())) {
      return "";
    }

    return new Intl.DateTimeFormat("sv-SE", {
      timeZone: "Asia/Tokyo",
      year: "numeric",
      month: "2-digit",
      day: "2-digit"
    }).format(dateObject);
  };

  /*
   * 年なしの日付
   */
  const formatShortDate = (value) => {
    const dateText = getDateText(value);

    if (!dateText) {
      return "";
    }

    const dateObject =
      new Date(dateText + "T00:00:00+09:00");

    return new Intl.DateTimeFormat("ja-JP", {
      timeZone: "Asia/Tokyo",
      month: "numeric",
      day: "numeric",
      weekday: "short"
    }).format(dateObject);
  };

  /*
   * 表示期間
   */
  const startDate =
    dates.length > 0
      ? getDateText(dates[0].value)
      : "";

  const endDate =
    dates.length > 0
      ? getDateText(dates[dates.length - 1].value)
      : "";

  const periodLabel =
    startDate && endDate
      ? formatShortDate(startDate) +
        " 〜 " +
        formatShortDate(endDate)
      : "";

  /*
   * 変更対象を維持するためのクエリ
   */
  const editQuery =
    isEditMode
      ? "&editReservationId=" +
        encodeURIComponent(
          String(changeReservationId)
        )
      : "";

  const previousWeekUrl =
    week > 0
      ? "/admin/reservations?week=" +
        (week - 1) +
        editQuery
      : null;

  const nextWeekUrl =
    canGoNextWeek
      ? "/admin/reservations?week=" +
        (week + 1) +
        editQuery
      : null;
%>

<div class="admin-page admin-reservations-page">
  <div class="admin-card">

    <header class="admin-page-header">

      <div>

        <p class="admin-page-eyebrow">
          <%= isEditMode
            ? "予約変更"
            : "予約管理"
          %>
        </p>

        <h1>
          <%= isEditMode
            ? "変更後の日時を選択"
            : "予約スケジュール"
          %>
        </h1>

        <p class="admin-page-description">
          担当医：
          <strong>
            <%= doctor.displayName || doctor.name %>
          </strong>
        </p>

      </div>

      <% if (isEditMode) { %>

        <a
          class="admin-week-button"
          href="/admin/reservations?week=<%= week %>"
        >
          変更を中止
        </a>

      <% } %>

    </header>

    <% if (isEditMode) { %>

      <section class="admin-panel">

        <h2 class="admin-panel-title">
          変更対象の予約
        </h2>

        <p class="admin-page-description">
          新しい日時の「○」または「△」を選択してください。
        </p>

        <div class="admin-list-table-shell">

          <table class="admin-info-table">

            <thead>
              <tr>
                <th>予約日</th>
                <th>時間</th>
                <th>担当医</th>
                <th>患者番号</th>
                <th>患者氏名</th>
              </tr>
            </thead>

            <tbody>
              <tr>

                <td>
                  <%= formatShortDate(
                    changeReservation.date
                  ) %>
                </td>

                <td>
                  <%= getSlotLabel(
                    changeReservation.slot,
                    changeReservation.doctorId
                  ) %>
                </td>

                <td>
                  <% if (changeReservation.doctor) { %>

                    <%= changeReservation.doctor.displayName
                      || changeReservation.doctor.name
                    %>

                  <% } else { %>

                    <%= doctor.displayName || doctor.name %>

                  <% } %>
                </td>

                <td>
                  <%= changeReservation.patientNumber %>
                </td>

                <td>
                  <strong>
                    <%= changeReservation.patient.name %>
                  </strong>
                </td>

              </tr>
            </tbody>

          </table>

        </div>

      </section>

    <% } %>

    <section class="admin-panel admin-schedule-panel">

      <div class="admin-schedule-toolbar">

        <div class="admin-toolbar-left">

          <% if (previousWeekUrl) { %>

            <a
              class="admin-week-button"
              href="<%= previousWeekUrl %>"
            >
              ‹ 前の週
            </a>

          <% } else { %>

            <span
              class="admin-week-button is-disabled"
              aria-disabled="true"
            >
              ‹ 前の週
            </span>

          <% } %>

        </div>

        <div class="admin-toolbar-center">

          <span class="admin-schedule-period-label">
            表示期間
          </span>

          <strong>
            <%= periodLabel %>
          </strong>

        </div>

        <div class="admin-toolbar-right">

          <% if (nextWeekUrl) { %>

            <a
              class="admin-week-button is-primary"
              href="<%= nextWeekUrl %>"
            >
              次の週 ›
            </a>

          <% } else { %>

            <span
              class="admin-week-button is-disabled"
              aria-disabled="true"
            >
              次の週 ›
            </span>

          <% } %>

        </div>

      </div>

      <div
        class="admin-status-guide"
        aria-label="予約状況"
      >

        <span>
          <b class="status-dot is-open">
            ○
          </b>

          <%= isEditMode
            ? "変更できます"
            : "空きあり"
          %>
        </span>

        <span>
          <b class="status-dot is-few">
            △
          </b>
          残り1人
        </span>

        <span>
          <b class="status-dot is-full">
            満
          </b>
          満員
        </span>

        <span>
          <b class="status-dot is-closed">
            休
          </b>
          休診
        </span>

        <span>
          <b class="status-dot is-closed">
            −
          </b>
          診療時間外
        </span>

      </div>

      <div class="admin-calendar-shell">

        <table class="admin-calendar-table">

          <thead>
            <tr>

              <th class="admin-calendar-time-head">
                時間
              </th>

              <% dates.forEach((dateItem) => { %>

                <%
                  const dateText =
                    getDateText(dateItem.value);

                  const dateParts =
                    dateText
                      .split("-")
                      .map(Number);

                  const month =
                    dateParts[1];

                  const day =
                    dateParts[2];

                  const dateObject =
                    new Date(
                      dateText +
                      "T00:00:00+09:00"
                    );

                  const dayNumber =
                    dateObject.getDay();

                  const weekdays = [
                    "日",
                    "月",
                    "火",
                    "水",
                    "木",
                    "金",
                    "土"
                  ];

                  const weekday =
                    weekdays[dayNumber];
                %>

                <th
                  class="
                    admin-calendar-date-head
                    <%= dayNumber === 0
                      ? 'is-sunday'
                      : ''
                    %>
                    <%= dayNumber === 6
                      ? 'is-saturday'
                      : ''
                    %>
                  "
                >

                  <span class="admin-calendar-date">
                    <%= month %>/<%= day %>
                  </span>

                  <span class="admin-calendar-weekday">
                    <%= weekday %>
                  </span>

                </th>

              <% }) %>

            </tr>
          </thead>

          <tbody>

            <% slots.forEach((slot) => { %>

              <tr>

                <th class="admin-calendar-time-cell">
                  <%= getSlotLabel(
                    slot,
                    doctorId
                  ) %>
                </th>

                <% dates.forEach((dateItem) => { %>

                  <%
                    const date =
                      getDateText(
                        dateItem.value
                      );

                    const settingKey =
                      date + "_" + slot;

                    const setting =
                      slotSettings[settingKey] || {
                        isScheduled: false,
                        isOpen: false,
                        isOverride: false,
                        capacity: 0
                      };

                    const isScheduled =
                      setting.isScheduled === true;

                    const isOpen =
                      setting.isOpen === true;

                    const capacity =
                      Number(setting.capacity) || 0;

                    const slotReservations =
                      reservations.filter(
                        (reservation) => {
                          const isSameSlot =
                            getDateText(
                              reservation.date
                            ) === date &&
                            reservation.slot === slot &&
                            Number(
                              reservation.doctorId
                            ) === Number(doctorId);

                          const isChangeTarget =
                            isEditMode &&
                            Number(reservation.id) ===
                              changeReservationId;

                          return (
                            isSameSlot &&
                            !isChangeTarget
                          );
                        }
                      );

                    const reservationCount =
                      slotReservations.length;

                    const remaining =
                      Math.max(
                        0,
                        capacity -
                          reservationCount
                      );

                    const isPast =
                      date < today ||
                      isPastReservationSlot(
                        date,
                        slot
                      );

                    const isOutsidePeriod =
                      date > maxReservableText;

                    const isFull =
                      isOpen &&
                      capacity > 0 &&
                      reservationCount >= capacity;

                    let status = "closed";
                    let statusLabel = "−";

                    if (
                      isScheduled &&
                      !isPast &&
                      !isOutsidePeriod
                    ) {
                      if (!isOpen) {
                        status = "closed";
                        statusLabel = "休";
                      } else if (isFull) {
                        status = "full";
                        statusLabel = "満";
                      } else if (remaining === 1) {
                        status = "few";
                        statusLabel = "△";
                      } else {
                        status = "open";
                        statusLabel = "○";
                      }
                    }

                    const canSelectChange =
                      isEditMode &&
                      isScheduled &&
                      isOpen &&
                      !isPast &&
                      !isOutsidePeriod &&
                      !isFull;

                    const canOpenDetail =
                      !isEditMode &&
                      isScheduled &&
                      !isPast &&
                      !isOutsidePeriod;

                    const slotUrl =
                      "/admin/slot?date=" +
                      encodeURIComponent(date) +
                      "&slot=" +
                      encodeURIComponent(slot);
                  %>

                  <td
                    class="
                      admin-calendar-slot
                      is-<%= status %>
                      <%= setting.isOverride
                        ? 'has-override'
                        : ''
                      %>
                      <%= canSelectChange
                        ? 'is-change-selectable'
                        : ''
                      %>
                    "
                  >

                    <% if (canSelectChange) { %>

                      <form
                        method="POST"
                        action="/admin/edit/<%= changeReservationId %>/confirm"
                        class="admin-calendar-change-form"
                      >

                        <input
                          type="hidden"
                          name="date"
                          value="<%= date %>"
                        >

                        <input
                          type="hidden"
                          name="slot"
                          value="<%= slot %>"
                        >

                        <button
                          type="submit"
                          class="admin-calendar-slot-link admin-calendar-slot-button"
                          aria-label="<%= formatShortDate(date) %> <%= getSlotLabel(slot, doctorId) %>へ変更"
                        >

                          <span class="admin-calendar-status">
                            <%= statusLabel %>
                          </span>

                          <span class="admin-calendar-count">
                            <%= reservationCount %>/<%= capacity %>
                          </span>

                        </button>

                      </form>

                    <% } else if (canOpenDetail) { %>

                      <a
                        class="admin-calendar-slot-link"
                        href="<%= slotUrl %>"
                        aria-label="<%= formatShortDate(date) %> <%= getSlotLabel(slot, doctorId) %>の予約枠詳細"
                      >

                        <span class="admin-calendar-status">
                          <%= statusLabel %>
                        </span>

                        <% if (
                          isOpen &&
                          capacity > 0
                        ) { %>

                          <span class="admin-calendar-count">
                            <%= reservationCount %>/<%= capacity %>
                          </span>

                        <% } else if (!isOpen) { %>

                          <span class="admin-calendar-count">
                            休診
                          </span>

                        <% } %>

                      </a>

                    <% } else { %>

                      <span class="admin-calendar-slot-disabled">

                        <span class="admin-calendar-status">
                          <%= statusLabel %>
                        </span>

                        <% if (
                          isScheduled &&
                          isOpen &&
                          capacity > 0 &&
                          !isPast &&
                          !isOutsidePeriod
                        ) { %>

                          <span class="admin-calendar-count">
                            <%= reservationCount %>/<%= capacity %>
                          </span>

                        <% } %>

                      </span>

                    <% } %>

                  </td>

                <% }) %>

              </tr>

            <% }) %>

          </tbody>

        </table>

      </div>

      <p class="admin-schedule-note">

        <% if (isEditMode) { %>

          「○」または「△」の枠をタップすると、変更確認画面へ進みます。

        <% } else { %>

          枠をタップすると、予約枠詳細を確認できます。

        <% } %>

      </p>

    </section>

    <% if (isEditMode) { %>

      <div class="admin-slot-footer-actions">

        <a
          class="admin-week-button"
          href="/admin/reservations?week=<%= week %>"
        >
          変更を中止
        </a>

        <a
          class="admin-week-button"
          href="/admin/slot?date=<%= encodeURIComponent(changeReservation.date) %>&slot=<%= encodeURIComponent(changeReservation.slot) %>"
        >
          元の予約枠へ戻る
        </a>

      </div>

    <% } %>

  </div>
</div>

<%- include("partials/footer", {
  isAdminPage: true,
  isAdminLoggedIn
}) %>