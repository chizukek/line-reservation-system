<%- include("partials/header", { title: title || "エラー" }) %>

<div class="clinic-page">
  <div class="clinic-card error-box">

    <h1><%= heading || "エラー" %></h1>

    <div class="clinic-error">
      <%= message %>
    </div>

    <% if (detail) { %>
      <div class="reservation-box">
        <p style="margin: 0; font-weight: 700;">
          <%= detail %>
        </p>
      </div>
    <% } %>

    <div class="clinic-actions">
      <a class="clinic-sub-button" href="<%= backUrl || '/' %>">
        戻る
      </a>
    </div>

  </div>
</div>

<%- include("partials/footer") %>