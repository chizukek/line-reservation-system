app.post("/admin/cancel/:id", requireAdminLogin, async (req, res) => {
  await prisma.reservation.delete({
    where: {
      id: Number(req.params.id),
    },
  });

  res.render("admin-complete", {
    title: "キャンセル完了",
    message: "予約をキャンセルしました。",
    buttonText: "予約一覧へ戻る",
    buttonLink: "/admin",
  });
});