<%- include("partials/header", {
  title: "予約キャンセル確認"
}) %>

<div class="admin-page">
  <div class="admin-card">

    <div class="admin-header">
      <div>
        <h1>予約キャンセル確認</h1>
      </div>
    </div>

    <section class="admin-section">
  <div class="admin-table-wrapper">
    <table class="admin-table">
      <thead>
        <tr>
          <th>予約日</th>
          <th>時間</th>
          <th>担当医師</th>
          <th>患者番号</th>
          <th>患者氏名</th>
        </tr>
      </thead>

      <tbody>
        <tr>
          <td><%= formatJapaneseDate(reservation.date) %></td>
          <td><%= reservation.slot %></td>
          <td><%= reservation.doctor.displayName || reservation.doctor.name %></td>
          <td><%= reservation.patientNumber %></td>
          <td><%= reservation.patient.name %></td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

<div class="clinic-error" style="margin-top:20px;">
  この予約をキャンセルします。よろしいですか？
</div>

<form
  action="/admin/cancel/<%= reservation.id %>"
  method="POST"
  class="clinic-actions"
>
  <button class="clinic-danger-button">
    キャンセルする
  </button>

  <a
    class="clinic-sub-button"
    href="/admin/slot?doctorId=<%= reservation.doctorId %>&date=<%= reservation.date %>&slot=<%= encodeURIComponent(reservation.slot) %>"
  >
    戻る
  </a>
</form>

  </div>
</div>

<%- include("partials/footer") %>