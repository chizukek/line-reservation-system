<%- include("partials/header", { title: title }) %>

<% if (typeof showProgress !== "undefined" && showProgress) { %>
  <%- include("partials/progress", { step: 3 }) %>
<% } %>

<div class="clinic-page">
  <div class="clinic-card complete-box">

    <h1><%= heading %></h1>

    <p class="clinic-lead"><%= message %></p>

    <% if (reservation) { %>
      <section class="clinic-section">
        <h2>予約内容</h2>

        <div class="reservation-box">
          <div class="info-row">
            <span>予約日</span>
            <strong><%= reservation.date %></strong>
          </div>

          <div class="info-row">
            <span>時間</span>
            <strong><%= reservation.slot %></strong>
          </div>

          <div class="info-row">
            <span>診療科</span>
            <strong>心療内科</strong>
          </div>
        </div>
      </section>
    <% } %>

    <div class="clinic-actions">
      <a class="clinic-main-button" href="<%= typeof backUrl !== 'undefined' ? backUrl : '/mypage' %>">
        <%= typeof backLabel !== 'undefined' ? backLabel : 'マイページへ戻る' %>
      </a>
    </div>

  </div>
</div>

<%- include("partials/footer") %>