<%- include("partials/header", { title: "予約完了" }) %>
<% if (typeof showProgress !== "undefined" && showProgress) { %>
  <%- include("partials/progress", { step: 3 }) %>
<% } %>

<h1><%= heading %></h1>

<p><%= message %></p>

<% if (reservation) { %>
<p>予約日：<%= reservation.date %></p>
<p>時間：<%= reservation.slot %></p>
<% } %>

<a class="main-button" href="<%= typeof backUrl !== 'undefined' ? backUrl : '/mypage' %>">
  <%= typeof backLabel !== 'undefined' ? backLabel : 'マイページへ戻る' %>
</a>