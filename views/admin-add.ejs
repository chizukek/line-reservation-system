<%- include("partials/header", { title: "電話予約登録" }) %>

<div class="admin-page">
  <div class="admin-card">

    <h1>電話予約登録</h1>

    <p class="clinic-lead">
      電話で受け付けた予約を登録します。
    </p>

    <% if (error) { %>
      <div class="clinic-error">
        <%= error %>
      </div>
    <% } %>

    <form action="/admin/add/confirm" method="POST" class="admin-form-card">

      <label>
        <span>患者番号</span>
        <input
          type="text"
          name="patientNumber"
          inputmode="numeric"
          maxlength="5"
          autocomplete="off"
          placeholder="例：10001"
          required
        >
      </label>

      <label>
        <span>予約日</span>
        <input
          type="date"
          id="date"
          name="date"
          required
        >
      </label>

      <label>
        <span>予約時間</span>
        <select id="slot" name="slot" required>
          <% slots.forEach(slot => { %>
            <option value="<%= slot %>">
              <%= slot %>
            </option>
          <% }) %>
        </select>
      </label>

      <div class="clinic-actions">
        <button class="clinic-main-button" type="submit">
          内容を確認する
        </button>

        <a class="clinic-sub-button" href="/admin">
          戻る
        </a>
      </div>

    </form>

  </div>
</div>
<script>
const dateInput = document.getElementById("date");
const slotSelect = document.getElementById("slot");

async function loadSlots() {

  const date = dateInput.value;

  if (!date) return;

  const res = await fetch("/api/slots?date=" + date);

  const slots = await res.json();

  slotSelect.innerHTML = "";

  slots.forEach(slot => {

    const option = document.createElement("option");

    option.value = slot;

    option.textContent = slot;

    slotSelect.appendChild(option);

  });

}

dateInput.addEventListener("change", loadSlots);

if (dateInput.value) {
  loadSlots();
}

</script>

<%- include("partials/footer") %>