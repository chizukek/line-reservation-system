
<%- include("partials/header", {
  title: "予約追加",
  isAdminPage: true,
  isAdminLoggedIn
}) %>

<%
  const searchKeyword =
    typeof keyword !== "undefined"
      ? String(keyword || "")
      : "";

  const patientList =
    typeof patients !== "undefined" &&
    Array.isArray(patients)
      ? patients
      : [];

  const searchPerformed =
    typeof hasSearched !== "undefined"
      ? Boolean(hasSearched)
      : searchKeyword.length > 0;

  const registrationError =
    typeof registerError !== "undefined"
      ? registerError
      : null;

  const registrationSuccess =
    typeof registerSuccess !== "undefined"
      ? registerSuccess
      : null;

  const registrationPatient =
    typeof registeredPatient !== "undefined"
      ? registeredPatient
      : null;

  const confirmationPatient =
    typeof confirmPatient !== "undefined"
      ? confirmPatient
      : null;

  const patientNumberValue =
    typeof newPatientNumber !== "undefined"
      ? String(newPatientNumber || "")
      : "";

  const patientNameValue =
    typeof newPatientName !== "undefined"
      ? String(newPatientName || "")
      : "";
%>

<div class="admin-page admin-slot-patient-search-page">
  <div class="admin-card">

    <header class="admin-page-header">

      <div>
        <p class="admin-page-eyebrow">
          予約管理
        </p>

        <h1>
          予約追加
        </h1>

        <p class="admin-page-description">
          <%= formatJapaneseDateShort(date) %>
          ・
          <%= slotLabel %>
          ・
          <strong>
            <%= doctor.displayName || doctor.name %>
          </strong>
        </p>
      </div>

    </header>

    <% if (registrationPatient) { %>

      <section class="admin-section admin-registered-patient-section">

        <h2>
          患者登録完了
        </h2>

        <div
          class="admin-success"
          role="status"
        >
          <%= registrationSuccess || "以下の患者情報を登録しました。" %>
        </div>

        <div class="admin-list-table-shell">

          <table class="admin-list-table admin-info-table">

            <thead>
              <tr>
                <th>患者番号</th>
                <th>患者氏名</th>
                <th>現在の予約日時</th>
                <th>操作</th>
              </tr>
            </thead>

            <tbody>
              <tr>

                <td>
                  <%= registrationPatient.patientNumber %>
                </td>

                <td>
                  <strong>
                    <%= registrationPatient.name %>
                  </strong>
                </td>

                <td>
                  −
                </td>

                <td>
                  <a
                    class="admin-row-button is-add"
                    href="/admin/slot/confirm?doctorId=<%= doctorId %>&date=<%= encodeURIComponent(date) %>&slot=<%= encodeURIComponent(slot) %>&patientNumber=<%= encodeURIComponent(registrationPatient.patientNumber) %>"
                  >
                    この患者の予約を追加
                  </a>
                </td>

              </tr>
            </tbody>

          </table>

        </div>

      </section>

    <% } %>

    <section class="admin-section">

      <h2>
        患者検索
      </h2>

      <form
        method="GET"
        action="/admin/slot/patient-search"
        class="admin-search-form admin-patient-search-form"
      >

        <input
          type="hidden"
          name="doctorId"
          value="<%= doctorId %>"
        >

        <input
          type="hidden"
          name="date"
          value="<%= date %>"
        >

        <input
          type="hidden"
          name="slot"
          value="<%= slot %>"
        >

        <label>
          <span>
            患者番号または患者氏名
          </span>

          <input
            type="text"
            name="keyword"
            value="<%= searchKeyword %>"
            placeholder="患者番号または患者氏名を入力"
            autocomplete="off"
            autofocus
          >
        </label>

        <button
          type="submit"
          class="admin-primary-button"
        >
          検索
        </button>

      </form>

    </section>

    <% if (searchPerformed) { %>

      <section class="admin-section">

        <h2>
          検索結果
        </h2>

        <% if (patientList.length === 0) { %>

          <div class="admin-empty-state">
            該当する患者は見つかりませんでした。
          </div>

        <% } else { %>

          <div class="admin-list-table-shell">

            <table class="admin-list-table admin-info-table">

              <thead>
                <tr>
                  <th>患者番号</th>
                  <th>患者氏名</th>
                  <th>現在の予約日時</th>
                  <th>操作</th>
                </tr>
              </thead>

              <tbody>

                <% patientList.forEach((patient) => { %>

                  <%
                    const currentReservation =
                      Array.isArray(patient.reservations) &&
                      patient.reservations.length > 0
                        ? patient.reservations[0]
                        : null;

                    const reservationDoctor =
                      currentReservation &&
                      currentReservation.doctor
                        ? currentReservation.doctor
                        : null;
                  %>

                  <tr>

                    <td>
                      <%= patient.patientNumber %>
                    </td>

                    <td>
                      <strong>
                        <%= patient.name %>
                      </strong>
                    </td>

                    <td>

                      <% if (currentReservation) { %>

                        <div class="admin-current-reservation">

                          <div class="admin-current-reservation-date">
                            <%= formatJapaneseDateShort(
                              currentReservation.date
                            ) %>
                          </div>

                          <div class="admin-current-reservation-meta">

                            <% if (reservationDoctor) { %>

                              <span>
                                <%= reservationDoctor.displayName
                                  || reservationDoctor.name
                                %>
                              </span>

                              <span aria-hidden="true">
                                ・
                              </span>

                            <% } %>

                            <span>
                              <%= getSlotLabel(
                                currentReservation.slot,
                                currentReservation.doctorId
                              ) %>
                            </span>

                          </div>

                        </div>

                      <% } else { %>

                        −

                      <% } %>

                    </td>

                    <td>

                      <% if (currentReservation) { %>

                        <a
                          class="admin-row-button"
                          href="/admin/slot?doctorId=<%= currentReservation.doctorId %>&date=<%= encodeURIComponent(currentReservation.date) %>&slot=<%= encodeURIComponent(currentReservation.slot) %>"
                        >
                          詳細
                        </a>

                      <% } else { %>

                        <a
                          class="admin-row-button is-add"
                          href="/admin/slot/confirm?doctorId=<%= doctorId %>&date=<%= encodeURIComponent(date) %>&slot=<%= encodeURIComponent(slot) %>&patientNumber=<%= encodeURIComponent(patient.patientNumber) %>"
                        >
                          この患者を選択
                        </a>

                      <% } %>

                    </td>

                  </tr>

                <% }) %>

              </tbody>

            </table>

          </div>

        <% } %>

      </section>

    <% } %>

    <section class="admin-section">

      <h2>
        患者を新規登録
      </h2>

      <% if (registrationError) { %>

        <div
          class="admin-error"
          role="alert"
        >
          <%= registrationError %>
        </div>

      <% } %>

      <% if (confirmationPatient) { %>

        <p class="admin-page-description">
          以下の内容で患者登録を行います。よろしいですか？
        </p>

        <div class="admin-confirm-box">

          <div class="admin-confirm-row">

            <div class="admin-confirm-label">
              患者番号
            </div>

            <div class="admin-confirm-value">
              <%= confirmationPatient.patientNumber %>
            </div>

          </div>

          <div class="admin-confirm-row">

            <div class="admin-confirm-label">
              患者氏名
            </div>

            <div class="admin-confirm-value">
              <%= confirmationPatient.name %>
            </div>

          </div>

        </div>

        <div class="admin-confirm-actions">

          <form
            method="POST"
            action="/admin/slot/patient-register"
          >

            <input
              type="hidden"
              name="doctorId"
              value="<%= doctorId %>"
            >

            <input
              type="hidden"
              name="date"
              value="<%= date %>"
            >

            <input
              type="hidden"
              name="slot"
              value="<%= slot %>"
            >

            <input
              type="hidden"
              name="patientNumber"
              value="<%= confirmationPatient.patientNumber %>"
            >

            <input
              type="hidden"
              name="name"
              value="<%= confirmationPatient.name %>"
            >

            <button
              type="submit"
              class="admin-primary-button"
            >
              はい、登録する
            </button>

          </form>

          <a
            class="admin-secondary-button"
            href="/admin/slot/patient-search?doctorId=<%= doctorId %>&date=<%= encodeURIComponent(date) %>&slot=<%= encodeURIComponent(slot) %>&newPatientNumber=<%= encodeURIComponent(confirmationPatient.patientNumber) %>&newPatientName=<%= encodeURIComponent(confirmationPatient.name) %>"
          >
            いいえ、戻る
          </a>

        </div>

      <% } else { %>

        <form
          method="POST"
          action="/admin/slot/patient-register-confirm"
          class="admin-form-card admin-patient-register-form"
        >

          <input
            type="hidden"
            name="doctorId"
            value="<%= doctorId %>"
          >

          <input
            type="hidden"
            name="date"
            value="<%= date %>"
          >

          <input
            type="hidden"
            name="slot"
            value="<%= slot %>"
          >

          <div class="admin-form-row">

            <label>

              <span>
                患者番号
              </span>

              <input
                type="text"
                name="patientNumber"
                value="<%= patientNumberValue %>"
                placeholder="患者番号を入力"
                inputmode="numeric"
                autocomplete="off"
                maxlength="5"
                required
              >

            </label>

            <label>

              <span>
                患者氏名
              </span>

              <input
                type="text"
                name="name"
                value="<%= patientNameValue %>"
                placeholder="患者氏名を入力"
                autocomplete="off"
                maxlength="100"
                required
              >

            </label>

          </div>

          <div class="admin-form-actions">

            <button
              type="submit"
              class="admin-primary-button"
            >
              登録内容を確認
            </button>

          </div>

        </form>

      <% } %>

    </section>

    <div class="admin-slot-footer-actions">

      <a
        class="admin-week-button"
        href="/admin/slot?doctorId=<%= doctorId %>&date=<%= encodeURIComponent(date) %>&slot=<%= encodeURIComponent(slot) %>"
      >
        予約枠詳細へ戻る
      </a>

      <a
        class="admin-week-button"
        href="/admin/reservations"
      >
        予約スケジュールへ戻る
      </a>

    </div>

  </div>
</div>

<%- include("partials/footer", {
  isAdminPage: true,
  isAdminLoggedIn
}) %>

