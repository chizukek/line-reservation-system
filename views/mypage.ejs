<%- include("partials/header", { title: "マイページ" }) %>

<div class="clinic-page">
  <div class="clinic-card mypage-card">

    <h1>マイページ</h1>

    <p class="clinic-lead">
      <strong><%= patient.name %></strong> 様
      （患者番号：<%= patient.patientNumber %>）
    </p>

    <% if (reservation) { %>

      <section class="clinic-section">
        <h2>現在のご予約</h2>

        <div class="reservation-box">

          <div class="info-row">
            <span>診療日</span>
            <strong><%= reservation.date %></strong>
          </div>

          <div class="info-row">
            <span>時間</span>
            <strong><%= reservation.slot %></strong>
          </div>

          <div class="info-row">
            <span>診療科</span>
            <strong>心療内科</strong>
          </div>

        </div>

        <p class="clinic-note">
  予約を変更する場合も、新しい予約が確定するまで現在の予約は保持されます。
</p>

        <div class="clinic-actions">
  <a class="clinic-main-button" href="/change">
    予約を変更する
  </a>

  <form method="POST" action="/cancel">
    <input type="hidden" name="id" value="<%= reservation.id %>">
    <input type="hidden" name="from" value="mypage">

    <button class="clinic-sub-button" type="submit">
      予約をキャンセルする
    </button>
  </form>
</div>

      </section>

    <% } else { %>

      <section class="clinic-section">

        <div class="reservation-box">

          <p class="empty-message">
            現在予約はありません。
          </p>

          <a class="clinic-main-button" href="/new">
            新しい予約をとる
          </a>

        </div>

      </section>

    <% } %>

    <a class="clinic-logout" href="/logout">
      ログアウト
    </a>

  </div>
</div>

<%- include("partials/footer") %>